---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Stand Fast Solutions | Veteran-Owned Janitorial & Custodial Services">

<!-- HEADER -->
<header id="header">
  <nav class="container nav-inner">
    <a href="#hero" class="nav-logo">
      <img src="/images/logo.jpg" alt="Stand Fast Solutions Logo" />
      <div class="nav-logo-text">
        <span class="brand-top">Stand Fast</span>
        <span class="brand-bottom">Solutions</span>
      </div>
    </a>
    <ul class="nav-links" id="navLinks">
      <li><a href="#services">Services</a></li>
      <li><a href="#why">Why Us</a></li>
      <li><a href="#about">About</a></li>
      <li class="nav-cta"><a href="#contact">Request a Quote</a></li>
    </ul>
    <button class="nav-hamburger" id="hamburger" aria-label="Toggle menu">
      <span></span><span></span><span></span>
    </button>
  </nav>
</header>

<!-- HERO -->
<section id="hero">
  <div class="container hero-inner">
    <div class="hero-content">
      <div class="hero-badge">
        <span class="star">★</span>
        <span>Veteran-Owned &amp; Operated</span>
      </div>
      <h1 class="hero-title">
        Built on <span class="accent">Discipline.</span><br />
        Delivered with <span class="accent">Pride.</span>
      </h1>
      <p class="hero-text">
        Stand Fast Solutions brings military-grade standards to commercial and government janitorial and custodial services. When cleanliness matters, we stand fast.
      </p>
      <div class="hero-actions">
        <a href="#contact" class="btn btn-primary">Request a Quote</a>
        <a href="#services" class="btn btn-outline">Our Services</a>
      </div>
      <div class="hero-stats">
        <div class="stat-item">
          <div class="stat-num">100%</div>
          <div class="stat-label">Veteran Owned</div>
        </div>
        <div class="stat-item">
          <div class="stat-num">24/7</div>
          <div class="stat-label">Availability</div>
        </div>
        <div class="stat-item">
          <div class="stat-num">0</div>
          <div class="stat-label">Shortcuts Taken</div>
        </div>
      </div>
    </div>
    <div class="hero-visual">
      <div class="hero-logo-wrap">
        <div class="hero-glow"></div>
        <img src="/images/logo.jpg" alt="Stand Fast Solutions" />
      </div>
    </div>
  </div>
</section>

<!-- TRUST BAR -->
<div id="trust-bar">
  <div class="container trust-inner">
    <div class="trust-item"><span class="icon">🎖️</span> Veteran-Owned Business</div>
    <div class="trust-item"><span class="icon">✅</span> Bonded &amp; Insured</div>
    <div class="trust-item"><span class="icon">🏢</span> Commercial &amp; Government</div>
    <div class="trust-item"><span class="icon">🔒</span> Background-Checked Staff</div>
    <div class="trust-item"><span class="icon">📋</span> Free Estimates</div>
  </div>
</div>

<!-- SERVICES -->
<section id="services">
  <div class="container">
    <div class="services-header">
      <span class="section-label">What We Do</span>
      <h2 class="section-title">Janitorial &amp; Custodial Services</h2>
      <p class="section-subtitle">From daily office cleaning to full-scale facility maintenance, we bring the same mission-focused approach to every contract.</p>
    </div>
    <div class="services-grid">
      <div class="service-card">
        <div class="service-icon">🏢</div>
        <h3 class="service-title">Office &amp; Commercial Cleaning</h3>
        <p class="service-desc">Daily, weekly, or monthly cleaning of office spaces, lobbies, restrooms, break rooms, and common areas — executed to a standard your clients will notice.</p>
      </div>
      <div class="service-card">
        <div class="service-icon">🏛️</div>
        <h3 class="service-title">Government &amp; Federal Facilities</h3>
        <p class="service-desc">Security-cleared, background-checked crews ready for government buildings, military installations, and federal contracts. We understand the protocols.</p>
      </div>
      <div class="service-card">
        <div class="service-icon">🏥</div>
        <h3 class="service-title">Medical &amp; Healthcare Cleaning</h3>
        <p class="service-desc">Rigorous disinfection and sanitation protocols for clinics, medical offices, and healthcare facilities — meeting OSHA and CDC guidelines.</p>
      </div>
      <div class="service-card">
        <div class="service-icon">🏭</div>
        <h3 class="service-title">Industrial &amp; Warehouse</h3>
        <p class="service-desc">Floor scrubbing, pressure washing, and large-scale facility cleaning for warehouses, manufacturing plants, and industrial spaces.</p>
      </div>
      <div class="service-card">
        <div class="service-icon">🏫</div>
        <h3 class="service-title">Schools &amp; Educational Facilities</h3>
        <p class="service-desc">Safe, non-toxic cleaning solutions for classrooms, gyms, cafeterias, and hallways — keeping learning environments clean and healthy.</p>
      </div>
      <div class="service-card">
        <div class="service-icon">✨</div>
        <h3 class="service-title">Post-Construction Cleanup</h3>
        <p class="service-desc">Debris removal, deep cleaning, and final polish after construction or renovation so your space is move-in ready on schedule.</p>
      </div>
    </div>
  </div>
</section>

<!-- WHY US -->
<section id="why">
  <div class="container why-inner">
    <div class="why-content">
      <span class="section-label">Why Stand Fast</span>
      <h2 class="section-title">The Standard Others<br />Try to Match</h2>
      <p class="section-subtitle">Military service instills values that translate directly to commercial cleaning — attention to detail, accountability, and mission completion.</p>
      <ul class="why-list">
        <li class="why-item">
          <div class="why-check">✓</div>
          <div class="why-item-text">
            <strong>Mission-Driven Standards</strong>
            <p>Every task is approached with the discipline and precision learned in uniform. We don't cut corners — ever.</p>
          </div>
        </li>
        <li class="why-item">
          <div class="why-check">✓</div>
          <div class="why-item-text">
            <strong>Reliable &amp; Accountable</strong>
            <p>We show up when we say we will. No excuses, no surprises — just consistent, dependable service you can plan around.</p>
          </div>
        </li>
        <li class="why-item">
          <div class="why-check">✓</div>
          <div class="why-item-text">
            <strong>Fully Bonded &amp; Insured</strong>
            <p>Complete liability coverage and bonding protect your facility, your staff, and your peace of mind.</p>
          </div>
        </li>
        <li class="why-item">
          <div class="why-check">✓</div>
          <div class="why-item-text">
            <strong>Certified &amp; Compliant</strong>
            <p>OSHA-compliant processes, background-checked team members, and green-certified cleaning products available on request.</p>
          </div>
        </li>
      </ul>
    </div>
    <div class="why-visual">
      <div class="why-card"><div class="big-num">100%</div><p>Client Satisfaction Goal</p></div>
      <div class="why-card"><div class="big-num">0</div><p>Shortcuts Ever Taken</p></div>
      <div class="why-card"><div class="big-num">24/7</div><p>Scheduling Available</p></div>
      <div class="why-card"><div class="big-num">VOB</div><p>Verified Veteran Business</p></div>
    </div>
  </div>
</section>

<!-- ABOUT -->
<section id="about">
  <div class="container about-inner">
    <div class="about-img-wrap">
      <div class="about-img-placeholder">
        <img src="/images/logo.jpg" alt="Stand Fast Solutions" />
      </div>
      <div class="about-ribbon">
        <span class="rib-num">🇺🇸</span>
        <span class="rib-label">Veteran Owned</span>
      </div>
    </div>
    <div class="about-content">
      <span class="section-label">About Us</span>
      <h2 class="section-title">Serving with the Same Pride We Served Our Country</h2>
      <p>Stand Fast Solutions was founded by veterans who believe that the values forged in service — integrity, discipline, and excellence — belong in every business.</p>
      <p>After years of service, our founders recognized that the commercial cleaning industry needed what the military instills: a zero-defect mindset, accountability at every level, and a commitment to completing the mission no matter what.</p>
      <p>Whether we're cleaning a single office suite or managing a multi-building government contract, Stand Fast Solutions delivers the same unwavering standard — because your facility deserves nothing less.</p>
      <div class="vet-badge">
        <span>🎖️</span>
        Veteran-Owned &amp; Operated Business
      </div>
    </div>
  </div>
</section>

<!-- CONTACT -->
<section id="contact">
  <div class="container">
    <div style="text-align:center;margin-bottom:56px;">
      <span class="section-label">Get In Touch</span>
      <h2 class="section-title">Request a Free Quote</h2>
      <p class="section-subtitle" style="margin:0 auto;">Tell us about your facility and we'll get back to you with a no-obligation estimate — usually within one business day.</p>
    </div>
    <div class="contact-inner">
      <div class="contact-info">
        <span class="section-label">Contact Info</span>
        <h3 class="section-title" style="font-size:1.6rem;">Let's Talk About Your Needs</h3>
        <p class="section-subtitle" style="margin-bottom:40px;">Ready to bring military-grade cleanliness to your facility? Reach out and we'll build a custom service plan around your schedule and budget.</p>
        <div class="contact-detail">
          <div class="c-icon">📧</div>
          <div><span class="c-label">Email</span><span class="c-value">info@standfast.solutions</span></div>
        </div>
        <div class="contact-detail">
          <div class="c-icon">📞</div>
          <div><span class="c-label">Phone</span><span class="c-value">(555) 000-0000</span></div>
        </div>
        <div class="contact-detail">
          <div class="c-icon">🕐</div>
          <div><span class="c-label">Hours</span><span class="c-value">Mon – Fri: 8am – 6pm<br />Weekend by appointment</span></div>
        </div>
        <div class="contact-detail">
          <div class="c-icon">📍</div>
          <div><span class="c-label">Service Area</span><span class="c-value">Available Nationwide</span></div>
        </div>
      </div>
      <div class="contact-form">
        <form id="contactForm" novalidate>
          <div class="form-row">
            <div class="form-group">
              <label for="fname">First Name</label>
              <input type="text" id="fname" name="fname" placeholder="John" required />
            </div>
            <div class="form-group">
              <label for="lname">Last Name</label>
              <input type="text" id="lname" name="lname" placeholder="Smith" required />
            </div>
          </div>
          <div class="form-group">
            <label for="email">Email Address</label>
            <input type="email" id="email" name="email" placeholder="john@company.com" required />
          </div>
          <div class="form-group">
            <label for="phone">Phone Number</label>
            <input type="tel" id="phone" name="phone" placeholder="(555) 000-0000" />
          </div>
          <div class="form-group">
            <label for="service">Service Needed</label>
            <select id="service" name="service">
              <option value="">Select a service...</option>
              <option>Office &amp; Commercial Cleaning</option>
              <option>Government &amp; Federal Facilities</option>
              <option>Medical &amp; Healthcare Cleaning</option>
              <option>Industrial &amp; Warehouse</option>
              <option>Schools &amp; Educational Facilities</option>
              <option>Post-Construction Cleanup</option>
              <option>Other / Not Sure</option>
            </select>
          </div>
          <div class="form-group">
            <label for="message">Tell Us About Your Facility</label>
            <textarea id="message" name="message" placeholder="Square footage, frequency, any special requirements..."></textarea>
          </div>
          <button type="submit" class="btn btn-primary form-submit">Send Message</button>
        </form>
      </div>
    </div>
  </div>
</section>

<!-- FOOTER -->
<footer id="footer">
  <div class="container">
    <div class="footer-inner">
      <div class="footer-brand">
        <img src="/images/logo.jpg" alt="Stand Fast Solutions" />
        <p>Veteran-owned janitorial and custodial services built on the values of service, discipline, and excellence. When cleanliness matters — we stand fast.</p>
      </div>
      <div class="footer-col">
        <h4>Services</h4>
        <ul>
          <li><a href="#services">Office &amp; Commercial</a></li>
          <li><a href="#services">Government &amp; Federal</a></li>
          <li><a href="#services">Medical &amp; Healthcare</a></li>
          <li><a href="#services">Industrial &amp; Warehouse</a></li>
          <li><a href="#services">Schools &amp; Education</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h4>Company</h4>
        <ul>
          <li><a href="#about">About Us</a></li>
          <li><a href="#why">Why Stand Fast</a></li>
          <li><a href="#contact">Contact</a></li>
          <li><a href="#contact">Request a Quote</a></li>
        </ul>
      </div>
    </div>
    <div class="footer-bottom">
      <p>&copy; 2025 Stand Fast Solutions. All rights reserved. | <a href="https://standfast.solutions" style="color:var(--gold)">standfast.solutions</a></p>
      <span class="vet-owned">🎖️ Proudly Veteran-Owned &amp; Operated</span>
    </div>
  </div>
</footer>

</Layout>
