---
import Layout from '../layouts/Layout.astro';

const services = [
  {
    photo: '/images/8.png',
    title: 'Facilities & Janitorial Services',
    desc: 'Routine and detailed cleaning for offices, restrooms, common areas, and commercial buildings. Reliable crews, consistent standards.'
  },
  {
    photo: '/images/6.png',
    title: 'Grounds & Exterior Maintenance',
    desc: 'Exterior upkeep including pressure washing, grounds care, and property maintenance that keeps your facility looking its best.'
  },
  {
    photo: '/images/10.png',
    title: 'Industrial & Specialized Cleaning',
    desc: 'High-standard cleaning for industrial facilities, warehouses, and environments requiring protective protocols and certified crews.'
  },
  {
    photo: '/images/5.png',
    title: 'Additional Services Available',
    desc: "Don't see what you need? We tailor service solutions to fit. Reach out and ask."
  }
];

const gallery = [
  { src: '/images/1.png', alt: 'Commercial facility cleaning' },
  { src: '/images/2.png', alt: 'School hallway janitorial service' },
  { src: '/images/3.png', alt: 'Office floor cleaning' },
  { src: '/images/4.png', alt: 'Commercial floor mopping' },
  { src: '/images/7.png', alt: 'Professional cleaning team' },
  { src: '/images/9.png', alt: 'Detail cleaning service' },
];
---
<Layout title="Standfast Solutions | Facilities & Support Services in Las Vegas">

<!-- HERO -->
<section id="hero">
  <div class="container hero-inner">
    <div class="hero-content">
      <div class="hero-badge">
        <span class="star">★</span>
        <span>Service-Disabled Veteran-Owned Small Business</span>
      </div>
      <h1 class="hero-title">
        Steadfast Service.<br/>
        <span class="accent">Dependable Results.</span>
      </h1>
      <p class="hero-text">
        Standfast Solutions provides reliable facilities, maintenance, and support services to commercial and government clients across Las Vegas and Clark County.
      </p>
      <div class="hero-actions">
        <a href="/contact" class="btn btn-primary">Request a Quote</a>
        <a href="/services" class="btn btn-outline">View Capabilities</a>
      </div>
      <div class="hero-stats">
        <div class="stat-item">
          <div class="stat-num">SDVOSB</div>
          <div class="stat-label">Veteran-Owned</div>
        </div>
        <div class="stat-item">
          <div class="stat-num">24/7</div>
          <div class="stat-label">Availability</div>
        </div>
        <div class="stat-item">
          <div class="stat-num">LV</div>
          <div class="stat-label">Las Vegas &amp; Clark County</div>
        </div>
      </div>
    </div>
    <div class="hero-visual">
      <div class="hero-collage">
        <div class="hero-logo-main">
          <div class="hero-glow"></div>
          <img src="/images/logo.jpg" alt="Standfast Solutions" />
        </div>
        <div class="hero-col-photos">
          <div class="hero-col-photo"><img src="/images/1.png" alt="Professional facility cleaning" /></div>
          <div class="hero-col-photo"><img src="/images/3.png" alt="Office cleaning service" /></div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- TRUST BAR -->
<div id="trust-bar">
  <div class="container trust-inner">
    <div class="trust-item"><span class="icon">🎖️</span> Veteran-Owned &amp; Operated</div>
    <div class="trust-item"><span class="icon">✅</span> Bonded &amp; Insured</div>
    <div class="trust-item"><span class="icon">🏛️</span> Government &amp; Commercial Ready</div>
    <div class="trust-item"><span class="icon">🔒</span> Background-Checked Staff</div>
    <div class="trust-item"><span class="icon">📋</span> Free Estimates</div>
  </div>
</div>

<!-- ABOUT BLOCK -->
<section id="about" style="padding:96px 0;background:var(--white);">
  <div class="container about-inner">
    <div>
      <span class="section-label">Who We Are</span>
      <h2 class="section-title">Built on a Simple Promise</h2>
      <p style="font-size:0.95rem;color:var(--gray);margin-bottom:16px;">Standfast Solutions is a veteran-owned and operated company built on a simple promise: show up, do the work right, and stand behind it. We deliver facility and support services that keep your operations running, backed by responsive management and consistent quality.</p>
      <p style="font-size:0.95rem;color:var(--gray);margin-bottom:28px;">We work with commercial property managers, government agencies, and prime contractors who need a dependable partner they can count on.</p>
      <div class="vet-badge"><span>🎖️</span> Majority owned and operated by a service-disabled veteran</div>
    </div>
    <div class="about-img-wrap">
      <img src="/images/ryan-beemus.jpg" alt="Ryan Beemus — Principal Owner & Veteran" class="about-photo" />
      <div class="about-ribbon">
        <span class="rib-num" style="font-size:1rem;display:block;margin-bottom:4px;">Ryan Beemus</span>
        <span class="rib-label">Principal Owner &amp; Veteran</span>
      </div>
    </div>
  </div>
</section>

<!-- SERVICES -->
<section id="services" style="padding:96px 0;background:var(--light);">
  <div class="container">
    <div class="services-header">
      <span class="section-label">What We Do</span>
      <h2 class="section-title">Our Services</h2>
      <p class="section-subtitle">We provide a growing range of facility and support services. Whatever your site needs, we build a solution around it.</p>
    </div>
    <div class="services-grid">
      {services.map(s => (
        <div class="service-card">
          <div class="service-card-img">
            <img src={s.photo} alt={s.title} />
          </div>
          <div class="service-card-body">
            <h3 class="service-title">{s.title}</h3>
            <p class="service-desc">{s.desc}</p>
          </div>
        </div>
      ))}
    </div>
    <div style="text-align:center;margin-top:40px;">
      <a href="/services" class="btn btn-primary">View All Capabilities</a>
    </div>
  </div>
</section>

<!-- PHOTO GALLERY -->
<section style="padding:80px 0;background:var(--white);">
  <div class="container">
    <div style="text-align:center;margin-bottom:48px;">
      <span class="section-label">Our Work</span>
      <h2 class="section-title">Professionals in Action</h2>
    </div>
    <div class="gallery-grid">
      {gallery.map(g => (
        <div class="gallery-item">
          <img src={g.src} alt={g.alt} />
        </div>
      ))}
    </div>
  </div>
</section>

<!-- WHY STANDFAST -->
<section id="why" style="padding:96px 0;background:var(--navy);color:var(--white);">
  <div class="container why-inner">
    <div class="why-content">
      <span class="section-label">Why Standfast</span>
      <h2 class="section-title" style="color:var(--white);">Why Choose Standfast</h2>
      <p class="section-subtitle" style="color:rgba(255,255,255,0.65);margin-bottom:40px;">We are structured, dependable, and built to serve both commercial and government clients.</p>
      <ul class="why-list">
        <li class="why-item">
          <div class="why-check">✓</div>
          <div class="why-item-text">
            <strong>Veteran-Owned &amp; Operated</strong>
            <p>A service-disabled veteran-owned small business. Discipline and accountability are built in.</p>
          </div>
        </li>
        <li class="why-item">
          <div class="why-check">✓</div>
          <div class="why-item-text">
            <strong>Dependable by Design</strong>
            <p>Responsive management and consistent quality on every job. No surprises.</p>
          </div>
        </li>
        <li class="why-item">
          <div class="why-check">✓</div>
          <div class="why-item-text">
            <strong>Government &amp; Commercial Ready</strong>
            <p>Registered and structured to work with agencies, prime contractors, and private clients.</p>
          </div>
        </li>
        <li class="why-item">
          <div class="why-check">✓</div>
          <div class="why-item-text">
            <strong>Built to Scale With You</strong>
            <p>Need more than one service? We coordinate it so you have one point of contact.</p>
          </div>
        </li>
      </ul>
    </div>
    <div class="why-visual">
      <div class="why-card"><div class="big-num">SDVOSB</div><p>Veteran-Owned Business</p></div>
      <div class="why-card"><div class="big-num">24/7</div><p>Scheduling Available</p></div>
      <div class="why-card"><div class="big-num">Gov</div><p>Government Ready</p></div>
      <div class="why-card"><div class="big-num">LV</div><p>Las Vegas &amp; Clark County</p></div>
    </div>
  </div>
</section>

<!-- CTA BLOCK -->
<section style="padding:80px 0;background:var(--white);text-align:center;">
  <div class="container">
    <span class="section-label">Get Started</span>
    <h2 class="section-title" style="margin:0 auto 16px;">Ready for a partner you can count on?</h2>
    <p class="section-subtitle" style="margin:0 auto 36px;">Tell us about your site and what you need. We'll put together a straightforward quote.</p>
    <a href="/contact" class="btn btn-primary">Request a Quote</a>
  </div>
</section>

</Layout>
